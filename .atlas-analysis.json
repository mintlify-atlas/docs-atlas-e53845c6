  "keyFeatures": [
    "Flexible pricing models (subscriptions, credits, usage-based, seat-based)",
    "Stripe integration with automatic payment handling",
    "React hooks for seamless frontend integration",
    "Real-time usage tracking and limits",
    "Webhook support for billing events",
    "Self-hosted or cloud deployment",
    "TypeScript and Python SDKs",
    "Dashboard for managing products, customers, and analytics"
  ],
  "publicApiSurface": [
    "/attach - Handle all purchase flows, upgrades, downgrades",
    "/check - Verify customer access and remaining usage",
    "/track - Record usage events for metered features",
    "/customers - CRUD operations for customers",
    "/products - Manage products and pricing plans",
    "/features - Configure feature access and limits",
    "/invoices - Retrieve invoice data",
    "/events - Query usage events and analytics",
    "useAutumn() - React hook for client-side integration",
    "useCustomer() - React hook for customer data",
    "AutumnProvider - React context provider",
    "Hono adapter - Backend integration for Hono framework",
    "Next.js adapter - Backend integration for Next.js",
    "Better Auth plugin - Authentication integration"
  ]
